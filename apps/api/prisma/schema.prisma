generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("FREE")   // FREE | PRO | ENTERPRISE
  maxUsers  Int      @default(10)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
  leads Lead[]

  @@map("organizations")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String
  firstName      String
  lastName       String
  role           String   @default("AGENT")  // ADMIN | AGENT | VIEWER
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignedLeads Lead[]
  notes         Note[]
  tasks         Task[]
  activities    Activity[]

  @@map("users")
}

model Lead {
  id                String   @id @default(cuid())
  organizationId    String?
  organization      Organization? @relation(fields: [organizationId], references: [id])
  source            String
  status            String   @default("NEW")
  
  propertyAddress   String
  propertyCity      String
  propertyState     String
  propertyZip       String
  propertyType      String?
  bedrooms          Int?
  bathrooms         Float?
  sqft              Int?
  yearBuilt         Int?
  lotSize           Float?
  lastSaleDate      DateTime?
  lastSalePrice     Float?
  taxAssessedValue  Float?
  ownerOccupied     Boolean?
  hoaFee            Float?
  latitude          Float?
  longitude         Float?

  sellerFirstName   String
  sellerLastName    String
  sellerPhone       String
  sellerEmail       String?
  
  timeline          Int?
  askingPrice       Float?
  conditionLevel    String?
  distressSignals   Json?
  ownershipStatus   String?
  sellerMotivation  String?

  arv               Float?
  arvConfidence     Float?
  lastCompsDate     DateTime?
  
  challengeScore    Int      @default(0)
  authorityScore    Int      @default(0)
  moneyScore        Int      @default(0)
  priorityScore     Int      @default(0)
  totalScore        Int      @default(0)
  scoreBand         String   @default("DEAD_COLD")
  abcdFit           String?
  scoringRationale  String?
  lastScoredAt      DateTime?
  
  assignedToUserId  String?
  assignedTo        User?    @relation(fields: [assignedToUserId], references: [id])
  tags              Json?
  
  doNotContact      Boolean  @default(false)
  unsubscribedAt    DateTime?
  autoRespond       Boolean  @default(true)
  autoResponseCount Int      @default(0)
  autoResponseDate  DateTime?

  campPriorityComplete  Boolean @default(false)
  campMoneyComplete     Boolean @default(false)
  campChallengeComplete Boolean @default(false)
  campAuthorityComplete Boolean @default(false)

  sourceMetadata    Json?
  primaryPhoto      String?
  photos            Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Pipeline tracking
  stageChangedAt    DateTime  @default(now())
  daysInStage       Int       @default(0)
  lastTouchedAt     DateTime  @default(now())
  touchCount        Int       @default(0)
  aiRecommendation  String?

  // AI Analysis fields
  aiAnalysis        String?   // JSON string of full analysis
  aiDealRating      Int?      // 1-10 rating
  aiDealWorthiness  String?   // YES/NO/NEED_MORE_DATA
  aiProfitPotential String?   // HIGH/MEDIUM/LOW/UNKNOWN
  aiConfidence      Int?      // 0-100
  aiLastUpdated     DateTime?
  aiSummary         String?   // Brief summary for overview

  messages          Message[]
  comps             Comp[]
  compAnalyses      CompAnalysis[]
  tasks             Task[]
  notes             Note[]
  activities        Activity[]
  contract          Contract?
  dripSequence      DripSequence?
  callLogs          CallLog[]

  @@map("leads")
}

model Message {
  id          String    @id @default(cuid())
  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  direction   String
  status      String    @default("PENDING")
  body        String
  from        String
  to          String
  twilioSid   String?   @unique
  sentAt      DateTime?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("messages")
}

model Comp {
  id              String        @id @default(cuid())
  leadId          String
  lead            Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  analysisId      String?
  analysis        CompAnalysis? @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  address         String
  distance        Float
  soldPrice       Float
  soldDate        DateTime
  daysOnMarket    Int?
  bedrooms        Int?
  bathrooms       Float?
  sqft            Int?
  lotSize         Float?
  yearBuilt       Int?
  hasPool         Boolean       @default(false)
  hasGarage       Boolean       @default(false)
  isRenovated     Boolean       @default(false)
  propertyType    String?
  hoaFees         Float?
  schoolDistrict  String?
  photoUrl        String?
  sourceUrl       String?
  source          String        @default("manual")
  correlation     Float?
  latitude        Float?
  longitude       Float?
  features        Json?
  notes           String?
  similarityScore Int?
  selected        Boolean       @default(true)
  adjustmentAmount Float?
  adjustedPrice   Float?
  adjustmentNotes  String?
  createdAt       DateTime      @default(now())

  @@map("comps")
}

model CompAnalysis {
  id                String   @id @default(cuid())
  leadId            String
  lead              Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  mode              String   @default("ARV")
  maxDistance        Float    @default(3)
  timeFrameMonths   Int      @default(12)
  propertyStatus    Json     @default("[\"Sold\"]")
  propertyType      String   @default("Auto")
  confidenceScore   Int      @default(0)
  aiSummary         String?  @db.Text
  aiAssessment      String?  @db.Text  // Detailed wholesaler assessment (comp pool, market, deal viability)
  photoAnalysis     String?  @db.Text  // Room-by-room assessment from photo upload
  photoRepairLow    Int?               // Photo-based repair estimate low
  photoRepairHigh   Int?               // Photo-based repair estimate high
  arvEstimate       Float?
  arvLow            Float?
  arvHigh           Float?
  arvMethod         String   @default("average")
  avgAdjustment     Float?
  pricePerSqft      Float?
  adjustmentsEnabled Boolean @default(true)
  adjustmentConfig  Json?
  repairCosts       Float?
  repairFinishLevel String?
  repairNotes       String?  @db.Text
  repairItems       Json?
  dealType          String   @default("wholesale")
  assignmentFee     Float    @default(15000)
  maoPercent        Float    @default(70)
  savedToLead       Boolean  @default(false)
  comps             Comp[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("comp_analyses")
}

model Task {
  id          String    @id @default(cuid())
  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("tasks")
}

model Note {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notes")
}

model Activity {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  type        String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@map("activities")
}

model DripSequence {
  id              String   @id @default(cuid())
  leadId          String   @unique
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  status          String   @default("PENDING") // PENDING | ACTIVE | COMPLETED | CANCELLED
  currentStep     Int      @default(0)

  hasTimeline     Boolean  @default(false)
  hasCondition    Boolean  @default(false)
  hasOwnership    Boolean  @default(false)
  hasAskingPrice  Boolean  @default(false)

  initialDelayMs  Int      @default(60000)
  retryDelayMs    Int      @default(86400000)
  maxRetries      Int      @default(2)
  currentRetries  Int      @default(0)

  lastMessageAt   DateTime?
  lastReplyAt     DateTime?
  pausedReason    String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("drip_sequences")
}

model DripSettings {
  id                  String   @id @default("default")
  initialDelayMs      Int      @default(60000)
  nextQuestionDelayMs Int      @default(30000)
  retryDelayMs        Int      @default(86400000)
  maxRetries          Int      @default(2)
  demoMode            Boolean  @default(false)

  // AI Outreach Toggles
  aiSmsEnabled        Boolean  @default(false)   // master switch for AI SMS drip
  aiCallEnabled       Boolean  @default(false)   // master switch for AI outbound calls
  callDelayMs         Int      @default(120000)  // delay before auto-call fires (default 2 min)

  updatedAt           DateTime @updatedAt

  @@map("drip_settings")
}

model AiPrompt {
  id              String   @id @default(cuid())
  name            String
  scenario        String   @unique
  contextRules    Json
  systemPrompt    String   @db.Text
  exampleMessages Json?
  priority        Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("ai_prompts")
}

model Contract {
  id                String    @id @default(cuid())
  leadId            String    @unique
  lead              Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contractDate      DateTime
  buyerName         String?
  assignmentFee     Float?
  titleCompany      String?
  expectedCloseDate DateTime?
  actualCloseDate   DateTime?
  dispositionNotes  String?
  outcome           String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("contracts")
}

model CallLog {
  id          String   @id @default(cuid())
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  vapiCallId  String?  @unique
  status      String   @default("queued")
  type        String   @default("ai_outbound")
  transcript  String?  @db.Text
  duration    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("call_logs")
}
