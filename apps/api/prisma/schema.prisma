generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("FREE")   // FREE | PRO | ENTERPRISE
  maxUsers  Int      @default(10)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  leads         Lead[]
  orgGmailToken OrgGmailToken?
  savedSearches SavedSearch[]

  @@map("organizations")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String
  firstName      String
  lastName       String
  role           String   @default("AGENT")  // ADMIN | AGENT | VIEWER
  phone          String?
  title          String?
  avatarUrl      String?  @db.Text
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignedLeads Lead[]
  notes         Note[]
  tasks         Task[]
  activities    Activity[]
  gmailToken    GmailToken?
  savedSearches SavedSearch[]
  aiCompCurations AiCompCuration[]

  @@map("users")
}

model Lead {
  id                String   @id @default(cuid())
  organizationId    String?
  organization      Organization? @relation(fields: [organizationId], references: [id])
  source            String
  status            String   @default("NEW")
  
  propertyAddress   String
  propertyCity      String
  propertyState     String
  propertyZip       String
  propertyType      String?
  bedrooms          Int?
  bathrooms         Float?
  sqft              Int?
  sqftOverride      Int?              // Manual override — used instead of ATTOM sqft for ARV calculations
  yearBuilt         Int?
  lotSize           Float?
  lastSaleDate      DateTime?
  lastSalePrice     Float?
  taxAssessedValue  Float?
  ownerOccupied     Boolean?
  hoaFee            Float?
  latitude          Float?
  longitude         Float?

  sellerFirstName   String
  sellerLastName    String
  sellerPhone       String
  sellerEmail       String?
  smrtphoneContactId Int?    // Smrtphone contact ID (created on initial outreach)
  
  timeline          Int?
  askingPrice       Float?
  conditionLevel    String?
  distressSignals   Json?
  ownershipStatus   String?
  sellerMotivation  String?

  arv               Float?
  arvConfidence     Float?
  lastCompsDate     DateTime?
  currentArvCalculationId String?
  currentArvCalculation   AiArvCalculation? @relation("LeadCurrentArvCalculation", fields: [currentArvCalculationId], references: [id], onUpdate: NoAction, onDelete: SetNull)
  currentArvUpdatedAt     DateTime?
  compsProvider     String?  @default("reapi") // 'reapi' | 'batchdata' | 'auto' — last-used comp provider per lead
  repairCosts       Float?   // Deal-level repair cost override
  assignmentFee     Float?   // Deal-level assignment fee override
  maoPercent        Float?   // MAO % override (default 70)

  // ── ATTOM enrichment (written by Deal Search flow) ───────────────────────
  attomId              String?   // ATTOM property ID for lookups
  attomEnrichedAt      DateTime? // when ATTOM data was last fetched
  attomAvm             Float?    // ATTOM AVM estimate
  attomAvmLow          Float?
  attomAvmHigh         Float?
  avmPoorHigh          Float?    // Condition-adjusted: distressed/AS-IS value
  avmExcellentHigh     Float?    // After-repair/renovated ARV ← TRUE ARV
  marketAssessedValue  Float?    // Market assessed value (provider-neutral)
  annualTaxAmount      Float?    // Actual annual property tax
  propertyCondition    String?   // GOOD / FAIR / POOR
  propertyQuality      String?   // EXCELLENT / GOOD / AVERAGE / FAIR / POOR
  wallType             String?   // BRICK / FRAME / STUCCO etc.
  stories              Int?      // Number of stories/levels
  basementSqft         Int?      // Basement square footage
  effectiveYearBuilt   Int?      // Renovation/effective year
  subdivision          String?   // Subdivision/neighborhood name
  coolingType          String?   // CENTRAL / EVAPORATIVE / etc.
  heatingType          String?   // FORCED AIR / BASEBOARD / etc.
  apn                  String?   // Assessor's Parcel Number
  ownerName            String?   // Owner name from assessment records

  // ── BatchData enrichment (validation phase) ──────────────────────────────
  batchdataLookupData      Json?     // Full BatchData property lookup response
  batchdataLookupFetchedAt DateTime? // When BatchData lookup was last fetched
  dataProviderConflicts    Json?     // Log of fields where REAPI and BatchData disagreed

  // ── RealEstateAPI (REAPI) enrichment ─────────────────────────────────────
  reapiId                 String?   // REAPI property ID for subsequent lookups
  reapiEnrichedAt         DateTime? // when REAPI data was last fetched
  reapiEstimatedValue     Float?    // REAPI AVM point estimate
  reapiEstimatedValueLow  Float?
  reapiEstimatedValueHigh Float?
  reapiEquity             Float?    // Estimated owner equity
  reapiMortgageData       Json?     // Current mortgage(s): lender, amount, rate, type, term, origination, lien position
  reapiSaleHistory        Json?     // Prior sales from REAPI
  reapiFeatures           Json?     // pool, garage, basement, stories, heating/cooling, condition, etc.
  reapiOwnerData          Json?     // Owner name(s), mailing address, owner-occupied, LLC flag

  // ── REAPI MLS add-on (v2/MLSDetail) ──────────────────────────────────────
  reapiMlsListingId       String?   // current/most-recent MLS listing ID
  reapiMlsNumber          String?   // board-assigned MLS number
  reapiMlsStatus          String?   // standardStatus from latest listing (Active/Pending/Sold/Cancelled/...)
  reapiMlsListPrice       Float?
  reapiMlsSoldPrice       Float?
  reapiMlsListDate        DateTime?
  reapiMlsSoldDate        DateTime?
  reapiMlsDaysOnMarket    Int?
  reapiMlsHistory         Json?     // [{ price, status, statusDate, daysOnMarket, agentName, ... }]
  reapiMlsPhotos          Json?     // [{ lowRes, midRes, highRes }]
  reapiMlsAgent           Json?     // { fullName, email, phone, mlsCode, officeName }
  reapiMlsRemarks         String?   // publicRemarks (listing description)

  // DEPRECATED: Score system being phased out. Do not extend.
  // Replacement strategy TBD — likely a derived freshness/momentum metric.
  // See docs/build-prompts/README.md.
  challengeScore    Int      @default(0)
  authorityScore    Int      @default(0)
  moneyScore        Int      @default(0)
  priorityScore     Int      @default(0)
  totalScore        Int      @default(0)
  scoreBand         String   @default("DEAD_COLD")
  abcdFit           String?
  scoringRationale  String?
  lastScoredAt      DateTime?
  
  assignedToUserId  String?
  assignedTo        User?    @relation(fields: [assignedToUserId], references: [id])
  assignedStage     String?
  assignedAt        DateTime?
  tags              Json?
  
  doNotContact      Boolean  @default(false)
  unsubscribedAt    DateTime?
  autoRespond       Boolean  @default(true)
  autoResponseCount Int      @default(0)
  autoResponseDate  DateTime?

  campPriorityComplete  Boolean @default(false)
  campMoneyComplete     Boolean @default(false)
  campChallengeComplete Boolean @default(false)
  campAuthorityComplete Boolean @default(false)

  // Deal tier: 1 = contract now, 2 = opportunity, 3 = dead/no go
  tier                  Int?

  sourceMetadata    Json?
  primaryPhoto      String?
  photos            Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Pipeline tracking
  stageChangedAt    DateTime  @default(now())
  daysInStage       Int       @default(0)
  lastTouchedAt     DateTime  @default(now())
  touchCount        Int       @default(0)
  aiRecommendation  String?

  // Hero strip AI insight (one-line lead-state summary, cached by state fingerprint)
  aiInsight             String?
  aiInsightGeneratedAt  DateTime?
  aiInsightState        String?   // fingerprint of (stage, tier, lastMessageId, offerCount, campCompleteness)

  // Alert dismissals for contradiction detector (keyed by ruleId → fingerprint)
  alertDismissals       Json?     // { [ruleId: string]: { fingerprint: string, dismissedAt: string } }

  // ── Disposition v2: post-acquisition tracking ────────────────────────────
  acquiredDate     DateTime?  // denormalized from contract.acquiredAt
  soldDate         DateTime?  // denormalized from finalSale.closedAt
  realizedProfit   Float?     // cached output of ProfitCalculationService.recalculate
  profitBucket     String?    @default("potential") // potential | expected | realized
  targetSalePrice  Float?     // disposition target; distinct from arv (comp valuation)

  messages          Message[]
  emails            Email[]
  comps             Comp[]
  compAnalyses      CompAnalysis[]
  tasks             Task[]
  notes             Note[]
  activities        Activity[]
  contract          Contract?
  offers            Offer[]
  dripSequence      DripSequence?
  callLogs          CallLog[]
  campaignEnrollments CampaignEnrollment[]
  dealShares          DealShare[]
  sellerPortal        SellerPortal?
  dispositionPlan     DispositionPlan?
  dispositionCosts    DispositionCost[]
  finalSale           FinalSale?
  aiCompCurations     AiCompCuration[]
  aiArvCalculations   AiArvCalculation[] @relation("LeadAiArvCalculations")

  @@index([organizationId, tier])
  @@index([organizationId, status])
  @@index([organizationId, totalScore])
  @@index([organizationId, createdAt])
  @@index([organizationId, lastTouchedAt])
  @@index([organizationId, propertyState])
  @@index([organizationId, scoreBand])
  @@index([organizationId, source])
  @@index([organizationId, profitBucket, status])
  @@index([organizationId, soldDate])
  @@index([organizationId, stageChangedAt])
  @@map("leads")
}

model Message {
  id          String    @id @default(cuid())
  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  direction   String
  status      String    @default("PENDING")
  body        String
  from        String
  to          String
  twilioSid   String?   // SmrtPhone message reference ID (not enforced unique — SmrtPhone doesn't guarantee unique IDs)
  sentAt      DateTime?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("messages")
}

model Comp {
  id              String        @id @default(cuid())
  leadId          String
  lead            Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  analysisId      String?
  analysis        CompAnalysis? @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  address         String
  distance        Float
  soldPrice       Float
  soldDate        DateTime
  daysOnMarket    Int?
  bedrooms        Int?
  bathrooms       Float?
  sqft            Int?
  lotSize         Float?
  yearBuilt       Int?
  hasPool         Boolean       @default(false)
  hasGarage       Boolean       @default(false)
  isRenovated     Boolean       @default(false)
  propertyType    String?
  hoaFees         Float?
  schoolDistrict  String?
  photoUrl        String?
  sourceUrl       String?
  apn             String?
  source          String        @default("manual") // 'manual' | 'reapi' | 'batchdata' | 'chatarv' | 'placeholder'
  correlation     Float?
  latitude        Float?
  longitude       Float?
  features        Json?
  notes           String?
  similarityScore Int?
  selected        Boolean       @default(true)
  adjustmentAmount Float?
  adjustedPrice   Float?
  adjustmentNotes  String?
  createdAt       DateTime      @default(now())

  @@map("comps")
}

model CompAnalysis {
  id                String   @id @default(cuid())
  leadId            String
  lead              Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  mode              String   @default("ARV")
  maxDistance        Float    @default(3)
  timeFrameMonths   Int      @default(12)
  propertyStatus    Json     @default("[\"Sold\"]")
  propertyType      String   @default("Auto")
  confidenceScore   Int      @default(0)
  aiSummary         String?  @db.Text
  aiAssessment      String?  @db.Text  // Detailed wholesaler assessment (comp pool, market, deal viability)
  photoAnalysis     String?  @db.Text  // Room-by-room assessment from photo upload
  photoRepairLow    Int?               // Photo-based repair estimate low
  photoRepairHigh   Int?               // Photo-based repair estimate high
  arvEstimate       Float?
  arvLow            Float?
  arvHigh           Float?
  arvMethod         String   @default("average")
  avgAdjustment     Float?
  pricePerSqft      Float?
  medianPricePerSqft Float?
  comparableSalesValue Float?
  // AI-adjusted ARV (input #2 to the blended ARV — input #1 is comparableSalesValue)
  aiArvEstimate     Float?
  aiArvLow          Float?
  aiArvHigh         Float?
  aiConfidence      Float?   // 0-100, matches confidenceScore scale
  adjustmentsEnabled Boolean @default(true)
  adjustmentConfig  Json?
  repairCosts       Float?
  repairFinishLevel String?
  repairNotes       String?  @db.Text
  repairItems       Json?
  dealType          String   @default("wholesale")
  assignmentFee     Float    @default(15000)
  maoPercent        Float    @default(70)
  savedToLead       Boolean  @default(false)

  // ── Three-model valuation ─────────────────────────────────────────────────
  costApproachValue     Float?   // Cost approach estimated value
  costApproachLandValue Float?   // Land value component
  costApproachBuildCost Float?   // Replacement build cost component
  costApproachDepreciation Float? // Depreciation applied
  incomeApproachValue   Float?   // Income/rental approach estimated value
  marketRent            Float?   // Market rent used in income approach
  marketRentEstimated   Boolean  @default(false)  // true = system-estimated (sqft-based), false = user-provided
  grossRentMultiplier   Float?   // GRM used (8-14 typical)
  triangulatedArv       Float?   // Final weighted triangulated value
  triangulatedArvLow    Float?
  triangulatedArvHigh   Float?
  methodsUsed           Json?    // Which valuation methods contributed
  methodDivergence      Float?   // % spread between highest and lowest method value
  neighborhoodCeiling   Float?   // Top 3 comp average as ceiling reference
  neighborhoodCeilingBreached Boolean @default(false)
  confidenceTier        String?  // "High" | "Medium" | "Low"

  // Phase 2: Risk flags and adjustments
  functionalObsolescenceAdj   Float?
  functionalObsolescenceNotes String?  @db.Text
  buyerPoolReduction          Float?
  buyerPoolNotes              String?  @db.Text
  landUtilityReduction        Float?
  landUtilityNotes            String?  @db.Text
  riskAdjustedArv             Float?
  riskFlags                   Json?
  sellerMotivationTier        String?
  sellerMotivationMaoPercent  Float?
  conditionTier               String?
  repairCostLow               Float?
  repairCostHigh              Float?
  negotiationRangeLow         Float?
  negotiationRangeHigh        Float?

  // Deal intelligence: full investor reasoning (market velocity, $/sqft anchoring,
  // multi-scenario exits, lot value, seller pitch)
  dealIntelligence  String?  @db.Text

  // ── PropGPT (REAPI AI-powered property analysis) ─────────────────────────
  propGptAnalysis   String?   @db.Text // Raw markdown/text response from PropGPT
  propGptArv        Float?             // Parsed ARV point estimate (best-effort regex)
  propGptArvLow     Float?
  propGptArvHigh    Float?
  propGptConfidence Float?             // 0-100
  propGptFetchedAt  DateTime?
  propGptModel      String?            // e.g. "gpt-4o"

  comps             Comp[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("comp_analyses")
}

model Task {
  id          String    @id @default(cuid())
  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  title       String
  description String?
  dueDate     DateTime?
  completed    Boolean   @default(false)
  completedAt  DateTime?
  reminderSent Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("tasks")
}

model Note {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notes")
}

model Activity {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  type        String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@map("activities")
}

model DripSequence {
  id              String   @id @default(cuid())
  leadId          String   @unique
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  status          String   @default("PENDING") // PENDING | ACTIVE | COMPLETED | CANCELLED
  currentStep     Int      @default(0)

  hasTimeline     Boolean  @default(false)
  hasCondition    Boolean  @default(false)
  hasOwnership    Boolean  @default(false)
  hasAskingPrice  Boolean  @default(false)

  initialDelayMs  Int      @default(60000)
  retryDelayMs    Int      @default(86400000)
  maxRetries      Int      @default(2)
  currentRetries  Int      @default(0)

  lastMessageAt   DateTime?
  lastReplyAt     DateTime?
  pausedReason    String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("drip_sequences")
}

model DripSettings {
  id                  String   @id @default("default")
  initialDelayMs      Int      @default(60000)
  nextQuestionDelayMs Int      @default(30000)
  retryDelayMs        Int      @default(86400000)
  maxRetries          Int      @default(2)
  demoMode            Boolean  @default(false)

  // AI Outreach Toggles
  aiSmsEnabled        Boolean  @default(false)   // master switch for AI SMS drip
  aiCallEnabled       Boolean  @default(false)   // master switch for AI outbound calls
  callDelayMs         Int      @default(120000)  // delay before auto-call fires (default 2 min)

  updatedAt           DateTime @updatedAt

  @@map("drip_settings")
}

model AiPrompt {
  id              String   @id @default(cuid())
  name            String
  scenario        String   @unique
  contextRules    Json
  systemPrompt    String   @db.Text
  exampleMessages Json?
  priority        Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("ai_prompts")
}

model Contract {
  id                   String    @id @default(cuid())
  leadId               String    @unique
  lead                 Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contractStatus       String    @default("draft")    // draft/signed/inspection/past-inspection/at-title/closed/cancelled
  exitStrategy         String    @default("wholesale") // wholesale/novation/subject-to/creative/retail
  offerAmount          Float?    // purchase price offered to seller
  earnestMoney         Float?
  inspectionPeriodDays Int?
  sellerFinancing      Boolean   @default(false)
  contractDate         DateTime?
  buyerName            String?
  assignmentFee        Float?
  titleCompany         String?
  expectedCloseDate    DateTime?
  actualCloseDate      DateTime?
  dispositionNotes     String?   @db.Text
  outcome              String?
  boldsignDocumentId   String?
  boldsignStatus       String?   // pending/completed/declined/revoked
  boldsignSigningUrl   String?   @db.Text
  boldsignSentAt       DateTime?

  // ── Disposition v2: acquisition tracking ─────────────────────────────────
  acceptedOfferId         String?  @unique
  acceptedOffer           Offer?   @relation("ContractAcceptedOffer", fields: [acceptedOfferId], references: [id])
  acquisitionClosingCosts Float?
  fundingSource           String?  // cash | hard_money | private_money | seller_finance | jv_capital | other
  acquiredAt              DateTime?

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@map("contracts")
}

model Offer {
  id               String    @id @default(cuid())
  leadId           String
  lead             Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  offerAmount      Float
  offerDate        DateTime  @default(now())
  status           String    @default("pending") // pending/accepted/rejected/countered/withdrawn
  counterAmount    Float?
  notes            String?
  visibleOnPortal  Boolean   @default(false)
  terms            String?   @db.Text
  sellerRespondedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  acceptedForContract Contract? @relation("ContractAcceptedOffer")

  @@map("offers")
}

model CallLog {
  id           String   @id @default(cuid())
  leadId       String?
  lead         Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  vapiCallId       String?  @unique
  smrtphoneCallId  String?  @unique
  status           String   @default("queued")
  type             String   @default("ai_outbound")
  transcript   String?  @db.Text
  summary      String?  @db.Text
  recordingUrl String?
  endedReason  String?
  duration     Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("call_logs")
}

model OrgGmailToken {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  accessToken    String
  refreshToken   String
  expiresAt      DateTime
  email          String       // e.g. deals@quickcashhomebuyers.com
  connectedBy    String       // userId of admin who connected it
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("org_gmail_tokens")
}

model GmailToken {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  email        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("gmail_tokens")
}

model Email {
  id          String   @id @default(cuid())
  orgId       String
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  gmailMsgId  String?  @unique
  threadId    String?
  direction   String
  fromAddress String
  toAddress   String
  subject     String
  bodyHtml    String?  @db.Text
  bodyText    String   @db.Text
  sentAt      DateTime
  createdAt   DateTime @default(now())

  @@map("emails")
}

// ─── Campaign / Re-engagement System ─────────────────────────────────────────

enum CampaignChannel {
  TEXT
  EMAIL
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  REPLIED
  OPTED_OUT
  REMOVED
}

enum DripMessageStatus {
  SENT
  DELIVERED
  BOUNCED
  FAILED
  SKIPPED
  OPENED
  CLICKED
  REPLIED
}

model Campaign {
  id             String   @id @default(cuid())
  name           String
  description    String?
  triggerDays    Int      @default(15)
  enrollmentMode String   @default("manual")  // "manual" | "auto"
  isActive       Boolean  @default(true)
  isDefault      Boolean  @default(false)
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  steps       CampaignStep[]
  enrollments CampaignEnrollment[]

  @@map("campaigns")
}

model CampaignStep {
  id              String          @id @default(cuid())
  campaignId      String
  campaign        Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  stepOrder       Int
  channel         CampaignChannel
  // delayDays/delayHours are CUMULATIVE offsets from CampaignEnrollment.enrolledAt,
  // not gaps from the previous step. A campaign with delays [0, 1, 2, 3] fires on
  // day 0, 1, 2, 3 from enrollment. See CampaignExecutionService.calculateNextSendAt.
  delayDays       Int             @default(0)
  delayHours      Int             @default(0)
  sendWindowStart String?
  sendWindowEnd   String?
  subject         String?
  body            String
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  messageLogs CampaignMessageLog[]

  @@map("campaign_steps")
}

model CampaignEnrollment {
  id               String           @id @default(cuid())
  campaignId       String
  campaign         Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leadId           String
  lead             Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  enrolledAt       DateTime         @default(now())
  currentStepOrder Int              @default(0)
  status           EnrollmentStatus @default(ACTIVE)
  nextSendAt       DateTime?
  lastContactAt    DateTime?
  completedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  messageLogs CampaignMessageLog[]

  @@unique([campaignId, leadId])
  @@map("campaign_enrollments")
}

model CampaignMessageLog {
  id           String             @id @default(cuid())
  enrollmentId String
  enrollment   CampaignEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  stepId       String
  step         CampaignStep       @relation(fields: [stepId], references: [id])
  channel      CampaignChannel
  sentAt       DateTime           @default(now())
  messageBody  String
  status       DripMessageStatus  @default(SENT)
  externalId   String?
  createdAt    DateTime           @default(now())

  @@map("campaign_message_logs")
}

// ─── Partners & Deal Sharing ─────────────────────────────────────────────────

model Partner {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String
  company        String?
  phone          String?
  type           String   @default("buyer")  // buyer | jv | title | lender | agent | other
  needsTypeReview Boolean @default(false)     // set during the legacy-type remap; user clears after reclassifying
  tags           Json     @default("[]")
  notes          String?  @db.Text
  isActive       Boolean  @default(true)
  lastSharedAt   DateTime?
  shareCount     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  dealShares          DealShare[]
  jvDispositionPlans  DispositionPlan[] @relation("DispoJvPartner")
  finalSalesAsBuyer   FinalSale[]       @relation("FinalSaleBuyer")

  @@unique([organizationId, email])
  @@map("partners")
}

model DealShare {
  id             String   @id @default(cuid())
  organizationId String
  leadId         String
  lead           Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  partnerId      String
  partner        Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  sharedByUserId String
  channel        String   @default("resend")  // resend | gmail | org-gmail

  viewToken      String   @unique
  expiresAt      DateTime

  status         String   @default("sent")  // sent | opened | expired | error
  openedAt       DateTime?
  openCount      Int      @default(0)
  lastOpenedAt   DateTime?

  // Snapshot of deal numbers at time of share
  snapshotArv           Float?
  snapshotRepairCosts   Float?
  snapshotMao           Float?
  snapshotAskingPrice   Float?
  snapshotAssignmentFee Float?
  snapshotDealType      String?

  emailSubject   String?
  personalNote   String?  @db.Text
  createdAt      DateTime @default(now())

  @@index([leadId])
  @@index([partnerId])
  @@index([viewToken])
  @@map("deal_shares")
}

// ─── Deal Search ─────────────────────────────────────────────────────────────

model DealSearchCache {
  id           String   @id @default(cuid())
  cacheKey     String   @unique              // SHA-256 hash of endpoint + geoIdV4 + params
  endpoint     String                        // ATTOM endpoint name
  geoIdV4      String                        // Area identifier (e.g. "ZI08902")
  params       Json                          // Full query params sent to ATTOM
  responseData Json                          // Raw ATTOM response
  resultCount  Int      @default(0)
  fetchedAt    DateTime @default(now())
  expiresAt    DateTime                      // fetchedAt + 48h (set in service code)

  @@index([cacheKey])
  @@index([expiresAt])
  @@map("deal_search_cache")
}

model SavedSearch {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  filters        Json                        // Serialized filter state
  resultCount    Int?
  lastRunAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("saved_searches")
}

model SellerPortal {
  id               String    @id @default(cuid())
  leadId           String    @unique
  lead             Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  viewToken        String    @unique
  status           String    @default("active") // active | disabled
  portalLinkSentAt DateTime?
  openedAt         DateTime?
  openCount        Int       @default(0)
  lastOpenedAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("seller_portals")
}

// Action Queue: per-user state for the dashboard Action Queue. The queue items
// themselves are computed on read; these tables only persist user intent
// (dismissals, snoozes) and a "last seen" marker for unseen badging.
model ActionDismissal {
  id          String   @id @default(cuid())
  userId      String
  actionKey   String
  dismissedAt DateTime @default(now())

  @@unique([userId, actionKey])
  @@index([userId])
  @@map("action_dismissals")
}

model ActionSnooze {
  id           String   @id @default(cuid())
  userId       String
  actionKey    String
  snoozedUntil DateTime

  @@unique([userId, actionKey])
  @@index([userId, snoozedUntil])
  @@map("action_snoozes")
}

model ActionLastSeen {
  userId     String   @id
  lastSeenAt DateTime @default(now())

  @@map("action_last_seen")
}

// ─── Disposition v2: post-acquisition lifecycle ──────────────────────────────

// Intended/actual disposition plan for a lead. One per lead. Created when the
// user sets an exit strategy (typically pre-acquisition or at acquisition).
model DispositionPlan {
  id              String    @id @default(cuid())
  leadId          String    @unique
  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  exitStrategy    String    // wholesale | novation | double_close | fix_flip | hold_rental | jv | sub_to | other
  targetSalePrice Float?
  targetCloseDate DateTime?
  jvPartnerId     String?
  jvPartner       Partner?  @relation("DispoJvPartner", fields: [jvPartnerId], references: [id])
  jvSplitMode     String?   // none | fifty_fifty | custom
  jvSplitPercent  Float?    // our-side percent when 'custom' (0-100)
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("disposition_plans")
}

// Line-item costs incurred between acquisition and final sale. Many per lead.
model DispositionCost {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  category    String   // holding | repair_prep | utilities | marketing | closing | jv_payout | other
  description String?
  amount      Float
  incurredAt  DateTime @default(now())
  paidTo      String?
  receiptUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([leadId])
  @@map("disposition_costs")
}

// Final sale event. One per lead. Created when the disposition closes.
model FinalSale {
  id               String   @id @default(cuid())
  leadId           String   @unique
  lead             Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  buyerName        String?
  buyerPartnerId   String?
  buyerPartner     Partner? @relation("FinalSaleBuyer", fields: [buyerPartnerId], references: [id])
  finalSalePrice   Float
  saleClosingCosts Float?
  netProceeds      Float?
  closedAt         DateTime
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("final_sales")
}

model AiCompCuration {
  id                     String   @id @default(cuid())
  leadId                 String
  userId                 String
  createdAt              DateTime @default(now())
  subjectSnapshot        Json
  valuationMode          String   // "ARV_RENOVATED" | "AS_IS"
  hardConstraints        Json
  candidateIds           String[]
  excludedTypeMismatches Json
  excludedConstraints    Json
  searchExpansion        Json
  promptText             String   @db.Text
  promptVersion          String
  rawResponse            Json
  parsedResponse         Json?
  modelMetadata          Json
  isValidationRun        Boolean  @default(false)
  validationPropertyId   String?
  cacheKey               String
  rawCandidateCount      Int?
  uniqueCandidateCount   Int?
  dedupMetadata          Json?
  lead                   Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user                   User     @relation(fields: [userId], references: [id])

  @@index([leadId, createdAt])
  @@index([cacheKey])
  @@map("ai_comp_curations")
}

model AiArvCalculation {
  id                String    @id @default(cuid())
  leadId            String
  lead              Lead      @relation("LeadAiArvCalculations", fields: [leadId], references: [id], onDelete: Cascade)
  curationId        String?
  inputHash         String
  mode              String    // "ARV_RENOVATED" | "AS_IS"
  arv               Float
  arvLow            Float?
  arvHigh           Float?
  pricePerSqft      Float?
  confidence        Int
  confidenceLabel   String    // "LOW" | "MEDIUM" | "HIGH"
  resultJson        Json
  selectedCompIds   String[]
  reapiAvmAtCalc    Float?
  modelUsed         String?
  promptVersion     String?
  computedAt        DateTime  @default(now())
  computedByUserId  String?

  currentForLeads   Lead[]    @relation("LeadCurrentArvCalculation")

  @@index([leadId, computedAt(sort: Desc)])
  @@index([leadId, inputHash])
  @@map("ai_arv_calculations")
}
