# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fast_homes_crm"

# Server
PORT=3001
FRONTEND_URL="http://localhost:3000"

# JWT
JWT_SECRET="your-secret-key-change-in-production"

# SMS provider selection
# Factory default: Smrtphone when SMRTPHONE_API_KEY is set, else Twilio, else simulator.
# Set SMS_PROVIDER=twilio to force Twilio while Smrtphone credentials remain configured
# (migration period). Other values: smrtphone.
SMS_PROVIDER=""

# SMS test mode (provider-agnostic): when true, outbound SMS only goes to allowlisted
# numbers. Legacy SMRTPHONE_TEST_MODE / SMRTPHONE_ALLOWED_NUMBERS still work as fallbacks.
SMS_TEST_MODE="false"
SMS_ALLOWED_NUMBERS=""  # comma-separated, e.g. "+17045551234,+18285555678"

# Twilio
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+15555551234"
# Delivery receipts: passed as statusCallback on every send.
# Point at this API's public URL.
TWILIO_STATUS_CALLBACK_URL="https://api.mydealcore.com/webhooks/twilio/status"
# Public base URL Twilio POSTs webhooks to - used for signature validation behind
# the Railway proxy. Set to the API's public origin (no trailing slash).
TWILIO_WEBHOOK_BASE_URL="https://api.mydealcore.com"
# Set to false to skip webhook signature validation (local/ngrok testing only)
TWILIO_VALIDATE_WEBHOOKS="true"

# Twilio browser dialer (Programmable Voice). Dormant until all three are set.
# API Key: Console > Account > API keys & tokens > Create API Key (Standard).
TWILIO_API_KEY_SID="SK..."
TWILIO_API_KEY_SECRET="your-api-key-secret"  # shown once at creation
# TwiML App: Console > Voice > TwiML > TwiML Apps. Set its Voice Request URL to
# https://<api-domain>/calls/twilio/voice  (this powers OUTBOUND browser calls)
TWILIO_TWIML_APP_SID="AP..."
# INBOUND: set your Twilio number's "A call comes in" Voice webhook to
# https://<api-domain>/calls/twilio/incoming  (rings the agents' browser dialers).
# Optional: restrict which client identities (userIds) ring; default rings all users.
TWILIO_INBOUND_RING_IDENTITIES=""  # e.g. "userId1,userId2"
# Call recording (off by default). Set true to record calls; the recording is
# transcribed via OpenAI (OPENAI_API_KEY) and run through CAMP extraction.
# When true, set a spoken disclosure for two-party-consent states.
TWILIO_RECORD_CALLS="false"
TWILIO_RECORDING_DISCLOSURE="This call may be recorded for quality purposes."

# Mobile push notifications (APNs). Dormant until all four are set. Powers
# new-lead / new-message alerts to the iOS app. Create an APNs Auth Key (.p8) at
# developer.apple.com > Certificates, IDs & Profiles > Keys (Apple Push Notifications).
APNS_AUTH_KEY_P8=""        # base64 of the .p8 file contents (base64 -i AuthKey_XXXX.p8)
APNS_KEY_ID=""             # 10-char Key ID shown next to the key
APNS_TEAM_ID=""            # Apple Developer Team ID
APNS_BUNDLE_ID="com.dealcore.app"  # the app's bundle identifier (APNs topic)
APNS_PRODUCTION="false"    # true once shipping via TestFlight/App Store
# For incoming-call (VoIP) push, create a Twilio Push Credential from the same APNs
# key (Console > Voice > Push Credentials) and set its SID here; the voice token
# endpoint attaches it for mobile clients (see docs/mobile-app-plan.md, phase 5).
TWILIO_APN_PUSH_CREDENTIAL_SID=""

# OpenAI (for AI features)
OPENAI_API_KEY="your-openai-api-key"

# RealEstateAPI (REAPI) — primary property / comps / mortgage / PropGPT provider
# Used for initial lead enrichment and as the default source on the Comps tab.
REAPI_API_KEY=""

# ATTOM_API_KEY — used by the Deal Search feature (property snapshot, foreclosure,
# skip-trace) and as an explicit comp source when chosen from the Comps tab.
ATTOM_API_KEY=""

# BatchData (validation phase — running side-by-side with REAPI on the Comps tab).
# Sandbox tokens hit the same URL but return canned dummy responses (free).
# Production tokens hit real data and bill per record returned.
BATCHDATA_API_KEY=""
BATCHDATA_ENVIRONMENT="sandbox"  # or 'production'
BATCHDATA_API_BASE_URL="https://api.batchdata.com/api/v1"

# Comp provider is now a per-lead setting controlled by the UI toggle on the comps-analysis page
# (stored on lead.compsProvider). No env var required.

# ChatARV.ai (optional - for real comps)
CHATARV_API_KEY=""

# Redis (for BullMQ - optional)
REDIS_HOST="localhost"
REDIS_PORT=6379

# Resend (for password reset emails)
RESEND_API_KEY=""
SMTP_FROM="Deal Core <noreply@mydealcore.com>"

# Campaign email sender (fallback display name if Organization.name is empty)
EMAIL_FROM_NAME="Quick Cash Home Buyers"

# Public base URL of this API — used to build email unsubscribe links
# Must be publicly reachable so Gmail one-click unsubscribe can POST to it
API_URL="https://api.mydealcore.com"

# Vapi AI Calling (optional)
VAPI_API_KEY="your-vapi-api-key"
VAPI_PHONE_NUMBER_ID="your-vapi-phone-number-id"
VAPI_WEBHOOK_SECRET="your-vapi-webhook-secret"
