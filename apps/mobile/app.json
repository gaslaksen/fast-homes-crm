{
  "expo": {
    "name": "Dealcore",
    "slug": "dealcore",
    "version": "0.1.0",
    "scheme": "dealcore",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dealcore.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "voip"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://api.mydealcore.com",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "19391db0-d1c5-420f-a480-abb2e071ec44"
      }
    }
  }
}
